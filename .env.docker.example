# Copy ke .env (di folder root, sejajar docker-compose.yml) lalu sesuaikan.
# docker compose otomatis membaca file bernama .env

# Port POS/admin di host (buka http://localhost:8080)
APP_PORT=8080
# Port Katalog konsumen di host (buka http://localhost:8090)
KATALOG_PORT=8090

# Database (internal container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=consumer_data_manager

# JWT — WAJIB diganti untuk produksi/online!
JWT_ACCESS_SECRET=ganti_dengan_secret_acak_panjang
JWT_REFRESH_SECRET=ganti_dengan_secret_acak_lain
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Origin frontend (untuk CORS). Saat online ganti ke domain Anda, mis. https://app.domain.com
CORS_ORIGIN=http://localhost:8080

# Seed data contoh saat pertama start (set false setelah produksi terisi data nyata)
SEED_ON_START=true
